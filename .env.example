# Application
APP_ENV=dev
LOG_LEVEL=INFO
APP_VERSION=0.1.0

# Postgres
POSTGRES_USER=alphalens
POSTGRES_PASSWORD=alphalens
POSTGRES_DB=alphalens
DATABASE_URL=postgresql+asyncpg://alphalens:alphalens@postgres:5432/alphalens
APP_DATABASE_URL=postgresql+psycopg://alphalens:alphalens@localhost:5432/alphalens
PERSISTENCE_BACKEND=in_memory

# Rate limiting
# Allowed backends: memory, redis
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_REDIS_URL=
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_LOGIN=10
RATE_LIMIT_AUTH_REGISTER=5
RATE_LIMIT_CHAT=60
RATE_LIMIT_SPEECH=10
RATE_LIMIT_REPORTS=20
RATE_LIMIT_SCENARIOS=20
RATE_LIMIT_FEEDBACK=30

# Redis
REDIS_URL=redis://redis:6379/0

# Caching (Redis when REDIS_URL is set; otherwise in-memory).
# Set CACHE_ENABLED=false to bypass caching entirely.
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300

# Conversation memory.
# Allowed backends: in_memory, redis
MEMORY_ENABLED=true
MEMORY_BACKEND=in_memory
MEMORY_TTL_SECONDS=3600

# Qdrant
QDRANT_URL=http://qdrant:6333
KNOWLEDGE_BASE_PATH=data/knowledge_base
RAG_COLLECTION=alphalens_kb
RAG_EMBEDDING_DIM=128

# Frontend
NEXT_PUBLIC_API_URL=/api/backend
BACKEND_INTERNAL_URL=http://localhost:8000

# LLM providers
# Leave OPENAI_API_KEY blank or set LLM_ENABLED=false to use the deterministic fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2
OPENAI_TOP_P=1.0
LLM_ENABLED=true
ANTHROPIC_API_KEY=

# Speech-to-text / multilingual chat
SPEECH_ENABLED=true
DEFAULT_RESPONSE_LANGUAGE=auto
SPEECH_MAX_UPLOAD_BYTES=26214400

# Market data
# Allowed providers: fallback, alpha_vantage
# Leave ALPHA_VANTAGE_API_KEY blank or set MARKET_DATA_PROVIDER=fallback to
# use the deterministic offline client (suitable for tests and dev).
ALPHA_VANTAGE_API_KEY=
MARKET_DATA_PROVIDER=fallback
MARKET_DATA_TIMEOUT_SECONDS=10

# Web/news search
# Allowed providers: fallback, serper
# Leave SERPER_API_KEY blank or set SEARCH_PROVIDER=fallback to use the
# deterministic offline client (suitable for tests and dev).
SERPER_API_KEY=
SEARCH_PROVIDER=fallback
SEARCH_TIMEOUT_SECONDS=10

# Macro economic data (FRED)
# Allowed providers: fallback, fred
# Leave FRED_API_KEY blank or set MACRO_DATA_PROVIDER=fallback to use the
# deterministic offline client (suitable for tests and dev).
# Get a free API key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
MACRO_DATA_PROVIDER=fallback
MACRO_DATA_TIMEOUT_SECONDS=10

# SEC EDGAR filings
# Allowed providers: fallback, sec_edgar
# Set SEC_PROVIDER=sec_edgar to retrieve real filing metadata from SEC EDGAR.
# No API key required; SEC requires a descriptive User-Agent header.
# The fallback returns deterministic realistic sections for dev/test/demo.
SEC_PROVIDER=fallback
SEC_TIMEOUT_SECONDS=10
SEC_USER_AGENT="AlphaLens AI contact@example.com"

# Observability
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT="AlphaLens AI"
